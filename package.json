{
  "name": "hearts",
  "private": true,
  "version": "0.3.38",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "icons": "node scripts/generate-icons.mjs",
    "sim": "SELFPLAY=1 vitest run src/sim/selfPlay.full.test.ts",
    "sim:euchre": "SELFPLAY=1 GAME=euchre MATCHES=100 vitest run src/sim/selfPlay.full.test.ts",
    "sim:spades": "SELFPLAY=1 GAME=spades MATCHES=100 vitest run src/sim/selfPlay.full.test.ts",
    "sim:hearts": "SELFPLAY=1 GAME=hearts MATCHES=50 vitest run src/sim/selfPlay.full.test.ts",
    "sim:all": "SELFPLAY=1 GAME=all MATCHES=50 vitest run src/sim/selfPlay.full.test.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@playwright/test": "^1.61.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "playwright-core": "^1.49.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1",
    "vitest": "^2.1.9"
  }
}
